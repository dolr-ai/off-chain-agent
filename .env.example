GOOGLE_SA_KEY=test
YRAL_METADATA_TOKEN="test_token"
QSTASH_CURRENT_SIGNING_KEY="test_key"
QSTASH_AUTH_TOKEN="test_token"
STORJ_INTERFACE_TOKEN="test_token"
SENTRY_ENVIRONMENT="development"

# Durable video processing worker. This replaces the video_upload_successful -> QStash path.
VIDEO_PROCESSING_WORKER_ENABLED=true
VIDEO_PROCESSING_DEDUP_DELAY_SECONDS=600
VIDEO_PROCESSING_WORKER_BATCH_SIZE=20
VIDEO_PROCESSING_WORKER_PARALLELISM=5
VIDEO_PROCESSING_WORKER_TICK_SECONDS=5
VIDEO_PROCESSING_MAX_DEDUP_ATTEMPTS=5
VIDEO_PROCESSING_MAX_NSFW_ENQUEUE_ATTEMPTS=20
VIDEO_PROCESSING_MAX_NSFW_POLL_ATTEMPTS=180
VIDEO_PROCESSING_MAX_NSFW_JOB_RETRIES=3
VIDEO_PROCESSING_NSFW_POLL_DELAY_SECONDS=60

# NSFW service internal API.
NSFW_API_BASE_URL="https://nsfw.ansuman.yral.com"
NSFW_INTERNAL_REQUEST_HMAC_SECRET="shared_secret"

# Hetzner S3 Object Storage Configuration
HETZNER_S3_ACCESS_KEY="your_access_key"
HETZNER_S3_SECRET_KEY="your_secret_key"
# Optional: Override default values if needed
# HETZNER_S3_ENDPOINT="https://fsn1.your-objectstorage.com"
# HETZNER_S3_BUCKET="yral-profile-images"
# HETZNER_S3_REGION="fsn1"
# HETZNER_S3_PUBLIC_URL_BASE="https://yral-profile-images.fsn1.your-objectstorage.com"
